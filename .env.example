# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Guild ID untuk deploy commands ke server tertentu (lebih cepat saat development)
GUILD_ID=your_guild_id_here

# Konfigurasi Text-to-Speech (TTS)
TTS_VOICE=id-ID-GadisNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# Zona Waktu untuk Reminder (Gunakan format IANA Timezone)
TIMEZONE=Asia/Jakarta

# SQLite Reminder DB (file dibuat otomatis; arahkan ke persistent volume saat deploy)
DATABASE_PATH=./data/voice-reminders.db
# Opsional: file reminder JSON lama yang akan dimigrasikan sekali
LEGACY_REMINDERS_FILE=./data/voice-reminders.json

# OpenRouter API Key (gratis: https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini API Key (fallback otomatis jika OpenRouter habis/error)
# Buat key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key & Model (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Cerebras API Key & Model (https://cloud.cerebras.ai/)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=Qwen/Qwen3-32B

# Routing AI: list provider dipisahkan koma. Order di bawah akan di-load-balance (round-robin) bergantian.
AI_PROVIDER_ORDER=openrouter,gemini,groq,cerebras
OPENROUTER_MODEL=openrouter/free
GEMINI_MODEL=gemini-2.5-flash-lite

# Opsional: fallback model diproses OpenRouter dalam satu HTTP request
# Pisahkan model ID dengan koma. Kosong = gunakan routing bawaan model primary.
OPENROUTER_FALLBACK_MODELS=

# Timeout per provider sebelum pindah otomatis ke provider berikutnya
AI_REQUEST_TIMEOUT_MS=12000

# Owner ID — Discord user ID kamu (klik kanan nama → Copy User ID)
# Owner bisa pakai /admin dan !admin untuk kontrol penuh bot
OWNER_ID=your_discord_user_id_here

# Tavily Search API Key (OPSIONAL tapi DISARANKAN — gratis 1000 credits/bulan)
# Daftar di: https://tavily.com/
# Tanpa ini, bot hanya pakai Wikipedia + DuckDuckGo untuk pencarian
TAVILY_API_KEY=
